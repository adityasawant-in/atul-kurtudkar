# Copy this file to .env.local (never commit .env.local) and fill in real
# values before connecting the contact form to a live backend.

# Endpoint the contact form POSTs { name, email, phone, message } to as
# JSON. If unset, the form falls back to a mock success response — useful
# for demos/reviews before a backend exists. Works out of the box with a
# form-handling service (Formspree, Getform, Basin) or your own serverless
# function.
VITE_CONTACT_FORM_ENDPOINT=
